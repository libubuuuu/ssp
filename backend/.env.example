# 复制为 .env 并填写所有值（不要提交 .env！）
# 必需
FAL_KEY=
JWT_SECRET=

# 可选（留空则使用默认值）
API_PREFIX=/api
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ai_creative

# 存储 (S3 兼容，如阿里云 OSS)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ai-creative

# 飞书 Webhook
FEISHU_WEBHOOK_URL=

# AI 服务
OPENAI_API_KEY=
RUNWAY_API_KEY=
