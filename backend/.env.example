# 复制为 .env 并填写
API_PREFIX=/api
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ai_creative

# 存储 (S3 兼容，如阿里云 OSS)
S3_ENDPOINT=
S3_ACCESS_KEY=
