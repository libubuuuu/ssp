*.tsbuildinfo
next-env.d.ts

# Temp
tmp/
studio_workspace/

# Runtime data (file-based queue/sessions; lives on the host, not in git)
jobs_data/
backups/
# BUG-2: 用户生成媒体归档(/opt/ssp/uploads,nginx /uploads/ alias);仅养成习惯,实际不在仓库
uploads/

# 任务队列持久化文件(各级)
jobs.json
**/jobs.json

# Editor / dev backups
*.bak
*.swp
*.swo

# Stray root-level lockfile (real lockfiles live in frontend/)
/package-lock.json

# Encrypted env can be tracked, plaintext must never be
.env.enc.unlocked
.env.*.local

# Shell-redirect mishaps that have shown up at repo root
/next
/frontend@*

# Tarball backups + master key (master key 泄漏 = 加密 env 报废)
*.tar.gz
.ssp_master_key

# Timestamped local backups (e.g. PROGRESS.md.bak.20260425-212957)
*.bak.*
