# SSP watchdog + 合成监控配置模板
# 安装位置:/root/.ssp-watchdog-config(chmod 600,只 root 可读)
#
# setup-fresh-server.sh 会自动从此模板创建初版,空字段需要后续手工填:
#   - 推送通道 token(任选一个或多个填,留空跳过该通道)
#   - 合成监控账号密码(setup-fresh-server.sh 会自动生成 + 创建数据库账号)
#
# ===========================================
# 1. 推送通道(任选一个填,告警自动推手机/群)
# ===========================================
#
# 1.1 PushPlus(微信,免费,扫码绑定)— 推荐个人用户
#     拿 token: https://www.pushplus.plus
# PUSHPLUS_TOKEN=
#
# 1.2 Server 酱(微信,5K/月免费,扫码)— 推荐个人用户
#     拿 SCKEY: https://sct.ftqq.com
SERVERCHAN_KEY=
#
# 1.3 企业微信群机器人(免费)— 推荐团队
#     企业微信群 → 设置 → 群机器人 → 添加 → 复制 webhook URL
# WECOM_WEBHOOK_URL=
#
# 1.4 飞书机器人(免费)
# FEISHU_WEBHOOK_URL=

# ===========================================
# 2. 合成用户测试账号
# ===========================================
# synthetic-user-test.sh 用这个账号每 30 分钟模拟真实用户操作
# setup-fresh-server.sh 会:
#   - 自动生成随机密码填到这里
#   - 同时在数据库创建 user 记录
SYNTHETIC_TEST_EMAIL=synthetic-monitor@ailixiao.com
SYNTHETIC_TEST_PASSWORD=
